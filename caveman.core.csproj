<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
  <PackageId>Caveman</PackageId>
  <Version>1.4.2</Version>
  <Authors>Francesco Paolo Passaro</Authors>
  <Company>Francesco Paolo Passaro</Company>
  <Description>NLP Prompt Compressor for LLMs. Reduces token usage by up to 70% using semantic contraction across 50+ languages. Licensed under the Caveman License (MIT + mandatory attribution to Passaro Francesco Paolo - Digitalsolutions.it). Bundled language data derived from Universal Dependencies (see NOTICE).</Description>
  <PackageTags>AI;NLP;LLM;PromptEngineering;Gemma3;MCP;Claude;Copilot</PackageTags>
  <RepositoryUrl>https://github.com/francescopaolopassaro/caveman</RepositoryUrl>
  <PackageReleaseNotes>1.4.2: language-quality pass ported back from the Synthelion (Python port) 1.2.0 quality review. Fixed: negation particles ("non"/"not"/"ne...pas"/"no"/"nicht"/"não"/"不") were being stripped as ordinary function words at every compression level, silently inverting sentence meaning -- now protected in eng/ita/fra/spa/deu/por/zho, with prefix-aware matching for Chinese compounds ("不是"/"不管"). Fixed Italian "subito" (adverb, "immediately") being mis-lemmatised to "subire" (verb, "to undergo") via a UD homograph-contaminated lemma entry -- LemmaOrLower now skips a lemma substitution when the surface form is POS-tagged ADV and the lemma differs. Added CavemanCjkSegmenter: dictionary-based Chinese word segmentation (DAG + dynamic-programming longest-match path, jieba's non-ML dictionary algorithm re-implemented rather than taken as a dependency) -- Chinese previously had no word segmentation at all, so compression and language detection both silently no-op'd beyond punctuation stripping. Repaired real mojibake corruption (UTF-8 mis-decoded as Windows-1252 at an earlier pipeline stage) in worddata/zho.yaml(.br), zho.pos.yaml.br, and _index.br (10 further affected languages: ben, ell, eng, heb, hin, jpn, kor, mar, tha, vie). Fixed language-detection data contamination: "john" (an English name) removed from 16 languages' function-word lists, "ha"/"e" (Italian words, not French) removed from French's list, and "ate" removed from Portuguese's exclusive markers (collided with English's own "ate"). All changes are additive and backward-compatible; 14 new regression tests (311/311 total).</PackageReleaseNotes>
  
  <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <OutputType>Library</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Title>Caveman</Title>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- Primary public API is documented; suppress "missing XML comment" for the rest. -->
    <NoWarn>$(NoWarn);CS1591</NoWarn>
    <Copyright>Copyright (c) 2026 Passaro Francesco Paolo - Digitalsolutions.it</Copyright>
    <PackageProjectUrl>https://github.com/francescopaolopassaro/caveman/</PackageProjectUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
<PropertyGroup>
  <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
  <PackageIcon>caveman-icon.png</PackageIcon>
  <PackageLicenseFile>LICENSE</PackageLicenseFile>
  <PackageRequireLicenseAcceptance>False</PackageRequireLicenseAcceptance>
</PropertyGroup>
  <ItemGroup>
    <Compile Remove="console\**" />
    <Compile Remove="tests\**" />
    <Compile Remove="scripts\**" />
    <Compile Remove="mcp\**" />
    <Compile Remove="copilot\**" />
    <EmbeddedResource Remove="console\**" />
    <EmbeddedResource Remove="tests\**" />
    <EmbeddedResource Remove="scripts\**" />
    <EmbeddedResource Remove="mcp\**" />
    <EmbeddedResource Remove="copilot\**" />
    <None Remove="console\**" />
    <None Remove="tests\**" />
    <None Remove="scripts\**" />
    <None Remove="mcp\**" />
    <None Remove="copilot\**" />
  </ItemGroup>

  <ItemGroup>
    <!-- Semantic Kernel plugins live in the separate Caveman.SemanticKernel package so the
         core stays dependency-free. The SemanticKernel folder is excluded from compilation. -->
    <Compile Remove="SemanticKernel\**" />
  </ItemGroup>

  <ItemGroup>
    <!-- Runtime artifacts produced by scripts/compile-worddata from worddata\*.yaml.
         The .yaml sources stay in the repo but are NOT embedded or packed. -->
    <EmbeddedResource Include="worddata\*.yaml.br" />
    <EmbeddedResource Include="worddata\_index.br" />
  </ItemGroup>

  <ItemGroup>
    <None Update="caveman-icon.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="LICENSE">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="NOTICE">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
